# ===========================================
# Dependencies (will be installed in Docker)
# ===========================================
node_modules
*/node_modules
apps/*/node_modules
packages/*/node_modules

# ===========================================
# Build outputs (will be built in Docker)
# ===========================================
dist
build
.next
apps/*/dist
apps/*/build
apps/*/.next
apps/docs/.vitepress/dist
apps/docs/.vitepress/cache

# ===========================================
# Git and Version Control
# ===========================================
.git
.gitignore
.gitattributes

# ===========================================
# Environment files
# ===========================================
.env*
!.env.example

# ===========================================
# IDE and Editor files
# ===========================================
.vscode
.idea
*.swp
*.swo
*.sublime-*
.editorconfig

# ===========================================
# OS files
# ===========================================
.DS_Store
Thumbs.db
desktop.ini

# ===========================================
# Logs
# ===========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===========================================
# Test and Coverage
# ===========================================
coverage
*.lcov
.nyc_output
**/*.test.ts
**/*.spec.ts
**/*.e2e-spec.ts
test/
tests/

# ===========================================
# CI/CD
# ===========================================
.github
.gitlab-ci.yml
.circleci
.travis.yml

# ===========================================
# Temporary files
# ===========================================
tmp
temp
*.tmp
*.temp

# ===========================================
# Docker context trimming
# ===========================================
Dockerfile.bak
docker/docker-compose*.yml

# ===========================================
# Cache directories
# ===========================================
.cache
.parcel-cache
.eslintcache
.turbo
.swc

# ===========================================
# Documentation (keep critical files)
# ===========================================
apps/docs/*
!apps/docs/package.json
*.md
!README.md

# ===========================================
# Miscellaneous
# ===========================================
.husky
.commitlintrc*
.prettierrc*
.eslintrc*
eslint.config.*
prettier.config.*
