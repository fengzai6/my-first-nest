{
  "name": "my-first-nest",
  "version": "0.1.0",
  "description": "My First NestJS Project For Learning - Monorepo",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "author": "fengzai6",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "dev": "yarn workspaces foreach -Ap run dev",
    "start": "yarn workspaces foreach -A run start",
    "lint": "yarn workspaces foreach -A run lint",
    "test": "yarn workspaces foreach -A run test",
    "clean": "yarn workspaces foreach -A run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "server:dev": "yarn workspace @my-first-nest/server dev",
    "server:build": "yarn workspace @my-first-nest/server build",
    "web:dev": "yarn workspace @my-first-nest/web dev",
    "web:build": "yarn workspace @my-first-nest/web build",
    "docs:dev": "yarn workspace @my-first-nest/docs dev",
    "docs:build": "yarn workspace @my-first-nest/docs build",
    "docker:build:server": "docker build -f apps/server/Dockerfile -t my-first-nest-server .",
    "docker:build:web": "docker build -f apps/web/Dockerfile -t my-first-nest-web ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fengzai6/my-first-nest.git"
  },
  "keywords": [
    "nestjs",
    "typescript",
    "nodejs",
    "react",
    "vitepress",
    "monorepo",
    "rbac",
    "swagger",
    "typeorm"
  ],
  "homepage": "https://github.com/fengzai6/my-first-nest",
  "bugs": {
    "url": "https://github.com/fengzai6/my-first-nest/issues"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.19.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "engines": {
    "node": ">=20.19.5"
  }
}
